# Public canonical URL used by metadata, robots, sitemap, and deployment checks.
# Production must use the final non-local HTTPS URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional server-only credential used by both generation endpoints.
# Without it, generation returns clearly labeled local GPT-5.6-shaped mock fixtures.
# The synthetic demo, benchmark, trajectory, and sign-off also work without it.
# Never prefix this with NEXT_PUBLIC_.
OPENAI_API_KEY=
